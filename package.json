{
  "name": "vault-service",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Benjamin Steinborn",
  "repository": {
    "type": "git",
    "url": "https://github.com/steinborndev/BrainVault.git"
  },
  "type": "module",
  "description": "Local ingestion service + dashboard on top of a claude-obsidian vault",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "test": "npm run test --workspace server",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace web",
    "lint": "npm run lint --workspace server",
    "ingest": "npm run ingest --workspace server --",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build:web": "npm run build --workspace web",
    "build:server": "npm run build --workspace server",
    "build": "npm run build:web && npm run build:server",
    "start": "npm run start --workspace server",
    "start:prod": "npm run start:prod --workspace server"
  }
}
