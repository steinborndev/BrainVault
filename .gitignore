node_modules/
dist/
coverage/

# Operational state — never committed (SPEC.md §8: SQLite holds runtime state only)
*.db
*.db-shm
*.db-wal
data/

# Credentials — must never enter the repo (CLAUDE.md hard rule 3)
.env
.env.*
*.token

# Windows / editor noise
*:Zone.Identifier
.DS_Store
*.log

# Test source documents (not ours to commit; CLAUDE.md: no generated artifacts)
*.pdf
*.docx
*.pptx
*.xlsx
*.url
*.URL
*.webloc
# Images only at the repo root are test drops; web/ PWA assets stay tracked.
/*.jpg
/*.jpeg
/*.JPG

# Build/tool caches and local editor/agent config
*.tsbuildinfo
.vite/
.vscode/
.idea/
.claude/settings.local.json
